# agent_runtime — configuration (copy to .env; all values have safe defaults in config.py)

# --- Valkey connection (shared valkey-bus) ---
# Inside the compose network the host is the service name; from the host it is 127.0.0.1.
VALKEY_HOST=valkey-bus
VALKEY_PORT=6379

# --- Stream conventions (MUST match agent_bus) ---
STREAM_PREFIX=stream:
DLQ_STREAM=stream:dlq
STREAM_TTL_S=3600

# --- Farm ingress (the shared stream the scheduler targets) ---
FARM_STREAM_ID=agent-runtime
CONSUMER_GROUP=cg:agent-runtime
CONSUMER_NAME=farm

# --- Consumer loop tuning ---
READ_COUNT=32
# Poll interval between non-blocking reads (ms). We never BLOCK on the read (glide
# multiplexes one connection, so a BLOCK would starve dispatched jobs' commands).
POLL_MS=250
REAPER_INTERVAL_S=15
REAPER_MIN_IDLE_MS=30000

# --- Dispatch bounds (never oversubscribe the shared brain) ---
MAX_CONCURRENCY=4
JOB_TIMEOUT_S=120

# --- Idempotency ---
DEDUPE_TTL_S=3600

# --- Agent registry ---
AGENTS_DIR=data/agents

# --- Downstream services ---
AGENT_SERVER_URL=http://agent_server:7701
# MCP tool host = the decoupled mcp-service (NOT noted). Requires joining noted-network.
MCP_SERVER_KEY=mcp
MCP_URL=http://mcp-service:8080/mcp/
WHATSAPP_BRIDGE_URL=http://whatsapp-bridge:3399
WHATSAPP_AGENT_NAME=news-agent
# Secret — set in .env, never in a DSL agent record. Leave empty to disable delivery.
WHATSAPP_TOKEN=

# --- Bus identity ---
SENDER_ID=agent-runtime

# --- Startup resilience (services come up across separate compose projects) ---
CONNECT_RETRIES=30
CONNECT_RETRY_DELAY_S=2

# --- HTTP API ---
API_HOST=0.0.0.0
API_PORT=6817

# --- Logging ---
LOG_LEVEL=INFO
