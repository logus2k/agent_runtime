{
  "_comment": "GOLDEN: expected runtime DSL for the News Agent (COMPLETE record — all fields the Patron model now captures). Regenerate: lower_graph(news_agent.graph.json).",
  "ok": true,
  "dsl": {
    "version": "0.1",
    "id": "ai-morning-news",
    "trigger": {
      "type": "schedule"
    },
    "brain": {
      "persona": "news_curator",
      "llm": {
        "temperature": 0.3,
        "max_tokens": 16384
      }
    },
    "description": "Morning AI headlines (NewsAPI) → L2K Chat",
    "enabled": true,
    "tools": {
      "server": "mcp",
      "allow": [
        "mcp__newsapi_search",
        "mcp__fetch_url"
      ],
      "max_rounds": 4
    },
    "memory": {
      "policy": "none",
      "max_turns": 20
    },
    "input": {
      "template": "Curate the {n} best morning headlines about {topic}.",
      "vars": {
        "n": 5,
        "topic": "AI agents"
      }
    },
    "delivery": {
      "channel": "whatsapp",
      "target": "120363427427912302@g.us",
      "target_name": "L2K Chat"
    }
  },
  "schedule": {
    "cron": "0 7 * * *",
    "timezone": "Europe/Lisbon"
  }
}
